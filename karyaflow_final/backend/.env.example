# WorkPulse (KaryaFlow HR) — Environment Configuration
# Rename this file to .env and fill in your values

# Security — change this to any long random string before going live
JWT_SECRET=karyaflow_change_this_in_production

# ─── DATABASE ────────────────────────────────────────────────
# For production (Render auto-provides this):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Leave empty for local SQLite development

# ─── FRONTEND URL (for CORS) ────────────────────────────────
# Set this to your Vercel URL in production
FRONTEND_URL=http://localhost:5000

# ─── EMAIL (Optional) ────────────────────────────────────────
# Without this the app works fully. Credentials are shown on screen.
# To enable emails: Gmail → Account → Security → App Passwords → create one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_digit_app_password
SMTP_FROM=noreply@yourcompany.com
